{
  "compilerOptions": {
    "lib": [
      "ES2023"
    ],
    "module": "commonjs",
    "moduleResolution": "Node",
    "allowJs": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "sourceMap": false,
    "declaration": false,
    "strict": true,
    "noImplicitAny": true,
    "target": "ES2020",
    "strictPropertyInitialization": false,
    "baseUrl": ".",
    "paths": {
      "tosu/*": [
        "../tosu/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
  ],
  "include": [
    "**/*"
  ],
  "references": [{ "path": "../tosu/tsconfig.base.json" }]
}